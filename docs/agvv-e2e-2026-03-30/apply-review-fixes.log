    """Markdown summary helpers."""
    
    
    def build_summary(title: str, lines: list[str]) -> str:
        """Build a compact markdown summary block for note lines."""
        normalized_title = " ".join(title.strip().split())
        normalized_lines = []
    
        for line in lines:
            normalized_line = " ".join(line.strip().split())
            if normalized_line:
                normalized_lines.append(f"- {normalized_line}")
    
        return "\n".join([f"## {normalized_title}", *normalized_lines])

