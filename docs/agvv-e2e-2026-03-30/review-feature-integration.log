    """Checklist rendering helpers."""
    
    
    def render_checklist(items: list[str]) -> str:
        """Render note items as a markdown checklist."""
        normalized_items = (" ".join(item.strip().split()) for item in items)
        return "\n".join(f"- [ ] {item}" for item in normalized_items if item)

